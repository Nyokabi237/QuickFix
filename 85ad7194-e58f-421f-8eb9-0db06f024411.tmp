<!-- ░░░░░░ TECH SIGNUP PAGE ░░░░░░ -->
<div id="page-tech-signup" class="page">
  <div style="padding-top:68px;">
    <div class="container" style="padding-top:48px;padding-bottom:60px;max-width:640px;">
      <span class="badge badge-yellow">JOIN US</span>
      <h1 style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:38px;margin:12px 0 8px;">Technician Registration</h1>
      <p style="color:var(--gray-light);margin-bottom:36px;">Join 850+ verified professionals earning steady income on QuickFix. Get approved in 24–48 hours.</p>
      <div style="background:var(--black-soft);border:1px solid var(--border);border-radius:16px;padding:36px;">
        <div style="display:flex;gap:0;border-radius:8px;overflow:hidden;border:1px solid var(--border);margin-bottom:28px;">
          <div style="flex:1;padding:10px;text-align:center;font-size:12px;font-weight:700;background:var(--yellow);color:var(--black);" id="ts1">1. Personal Info</div>
          <div style="flex:1;padding:10px;text-align:center;font-size:12px;font-weight:700;background:var(--gray);color:var(--gray-light);" id="ts2">2. Services &amp; Skills</div>
          <div style="flex:1;padding:10px;text-align:center;font-size:12px;font-weight:700;background:var(--gray);color:var(--gray-light);" id="ts3">3. Documents</div>
        </div>
        <div id="ts-step-1">
          <div class="form-group"><label class="form-label">Full Name</label><input class="form-input" id="ts-name" placeholder="John Mwangi"/></div>
          <div class="form-group"><label class="form-label">Phone / WhatsApp</label><input class="form-input" id="ts-phone" type="tel" placeholder="+254 7XX XXX XXX"/></div>
          <div class="form-group"><label class="form-label">Email</label><input class="form-input" id="ts-email" type="email" placeholder="john@email.com"/></div>
          <div class="form-group"><label class="form-label">Primary Base Area</label>
            <select class="form-select" id="ts-loc">
              <option value="">-- Select area --</option>
              <option>Westlands</option><option>Kilimani</option><option>Karen</option><option>Embakasi</option><option>Kasarani</option><option>Kileleshwa</option><option>Lavington</option><option>Ngong Road</option><option>CBD</option><option>Thika Road</option>
            </select>
          </div>
        </div>
        <div id="ts-step-2" class="hidden">
          <label class="form-label" style="margin-bottom:14px;">Select Your Services (choose all that apply)</label>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:20px;">
            <div class="service-toggle" id="stog-electrical" onclick="toggleServiceCheck('electrical')" style="display:flex;align-items:center;gap:10px;padding:14px;border-radius:8px;border:2px solid var(--border);cursor:pointer;transition:all .2s;">
              <span style="font-size:20px;">⚡</span><span style="font-weight:600;font-size:14px;">Electrical</span>
            </div>
            <div class="service-toggle" id="stog-solar" onclick="toggleServiceCheck('solar')" style="display:flex;align-items:center;gap:10px;padding:14px;border-radius:8px;border:2px solid var(--border);cursor:pointer;transition:all .2s;">
              <span style="font-size:20px;">☀️</span><span style="font-weight:600;font-size:14px;">Solar Systems</span>
            </div>
            <div class="service-toggle" id="stog-cctv" onclick="toggleServiceCheck('cctv')" style="display:flex;align-items:center;gap:10px;padding:14px;border-radius:8px;border:2px solid var(--border);cursor:pointer;transition:all .2s;">
              <span style="font-size:20px;">📷</span><span style="font-weight:600;font-size:14px;">CCTV &amp; Security</span>
            </div>
            <div class="service-toggle" id="stog-internet" onclick="toggleServiceCheck('internet')" style="display:flex;align-items:center;gap:10px;padding:14px;border-radius:8px;border:2px solid var(--border);cursor:pointer;transition:all .2s;">
              <span style="font-size:20px;">📶</span><span style="font-weight:600;font-size:14px;">Internet &amp; WiFi</span>
            </div>
          </div>
          <div class="form-group"><label class="form-label">Years of Experience</label><input class="form-input" id="ts-exp" type="number" placeholder="e.g. 5"/></div>
          <div class="form-group"><label class="form-label">Professional Bio</label><textarea class="form-textarea" id="ts-bio" rows="4" placeholder="Describe your skills, certifications, and specializations…"></textarea></div>
        </div>
        <div id="ts-step-3" class="hidden">
          <p style="color:var(--gray-light);font-size:14px;margin-bottom:24px;line-height:1.75;">Upload your documents for verification. All files are securely stored and reviewed by our compliance team within 24 hours.</p>
          <div class="upload-area" id="doc-id" onclick="toggleDocUpload('id')" style="margin-bottom:14px;">
            <div style="font-size:28px;margin-bottom:8px;" id="doc-id-icon">🪪</div>
            <div style="font-weight:700;margin-bottom:4px;">National ID (Front &amp; Back)</div>
            <div style="font-size:13px;color:var(--gray-light);" id="doc-id-status">Click to upload — JPG or PDF</div>
          </div>
          <div class="upload-area" id="doc-cert" onclick="toggleDocUpload('cert')">
            <div style="font-size:28px;margin-bottom:8px;" id="doc-cert-icon">📜</div>
            <div style="font-weight:700;margin-bottom:4px;">Professional Certificates / Licenses</div>
            <div style="font-size:13px;color:var(--gray-light);" id="doc-cert-status">Click to upload — JPG or PDF</div>
          </div>
          <div style="margin-top:20px;background:rgba(255,214,0,.08);border:1px solid rgba(255,214,0,.3);border-radius:8px;padding:14px;font-size:13px;color:var(--gray-light);">
            After submission, your profile will be reviewed within <strong style="color:var(--yellow);">24–48 hours</strong>. You'll receive an SMS and email once approved.
          </div>
        </div>
        <div style="display:flex;justify-content:space-between;margin-top:28px;gap:12px;">
          <button class="btn btn-ghost btn-md" id="ts-back-btn" onclick="tsBack()" style="visibility:hidden;">← Back</button>
          <button class="btn btn-primary btn-md" id="ts-next-btn" onclick="tsNext()">Continue →</button>
        </div>
      </div>
    </div>
  </div>
</div>

