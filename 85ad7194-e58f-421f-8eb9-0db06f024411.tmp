          <div style="text-align:center;padding:28px 20px;background:var(--black-soft);border:1px solid var(--border);border-radius:14px;"><div style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:44px;color:var(--yellow);">4.8★</div><div style="color:var(--gray-light);margin-top:6px;">Average Rating</div></div>
