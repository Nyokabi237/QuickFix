<!-- ░░░░░░ REQUEST SERVICE PAGE ░░░░░░ -->
<div id="page-request" class="page">
  <div style="padding-top:68px;">
    <div class="container" style="padding-top:48px;padding-bottom:60px;max-width:720px;">
      <span class="badge badge-yellow">REQUEST SERVICE</span>
      <h1 style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:38px;margin:12px 0 8px;">Describe Your Problem</h1>
      <p style="color:var(--gray-light);margin-bottom:36px;">Fill in the details below and we'll auto-match you with the best available technician nearby.</p>

      <!-- Step progress -->
      <div class="step-progress">
        <div class="step-dot active" id="sp1">1</div>
        <div class="step-line inactive" id="sl1"></div>
        <div class="step-dot inactive" id="sp2">2</div>
        <div class="step-line inactive" id="sl2"></div>
        <div class="step-dot inactive" id="sp3">3</div>
        <span style="margin-left:12px;font-size:13px;color:var(--gray-light);" id="step-label">Step 1 of 3 — Your Details</span>
      </div>

      <div style="background:var(--black-soft);border:1px solid var(--border);border-radius:16px;padding:36px;">
        <!-- Step 1 -->
        <div id="req-step-1">
          <div class="emergency-toggle" id="emerg-toggle" onclick="toggleEmergency()">
            <div style="display:flex;align-items:center;gap:12px;">
              <span style="font-size:24px;">🚨</span>
              <div><div style="font-weight:700;" id="emerg-label">Emergency Request</div><div style="font-size:13px;color:var(--gray-light);">Technician dispatched within 1 hour</div></div>
            </div>
            <div class="toggle-switch" id="emerg-switch"><div class="toggle-knob"></div></div>
          </div>
          <div class="form-group"><label class="form-label">Full Name</label><input class="form-input" id="r-name" placeholder="Your full name"/></div>
          <div class="form-group"><label class="form-label">Phone Number</label><input class="form-input" id="r-phone" type="tel" placeholder="+254 7XX XXX XXX"/></div>
          <div class="form-group"><label class="form-label">Location</label>
            <select class="form-select" id="r-loc">
              <option value="">-- Select your area --</option>
              <option>Westlands</option><option>Kilimani</option><option>Karen</option><option>Embakasi</option><option>Kasarani</option><option>Kileleshwa</option><option>Lavington</option><option>Ngong Road</option><option>CBD</option><option>Thika Road</option><option>Lang'ata</option><option>South B</option><option>Ruaka</option><option>Kikuyu</option>
            </select>
          </div>
          <div class="form-group"><label class="form-label">Service Type</label>
            <select class="form-select" id="r-svc">
              <option value="electrical">⚡ Electrical</option>
              <option value="solar">☀️ Solar Systems</option>
              <option value="cctv">📷 CCTV &amp; Security</option>
              <option value="internet">📶 Internet &amp; WiFi</option>
            </select>
          </div>
          <div class="form-group"><label class="form-label">Describe the Problem</label><textarea class="form-textarea" id="r-desc" rows="4" placeholder="e.g. Power keeps tripping in bedroom — suspect faulty wiring. Need urgent check and possible socket replacement."></textarea></div>
          <div class="upload-area">
            <div style="font-size:32px;margin-bottom:8px;">📎</div>
            <div style="font-weight:600;margin-bottom:4px;">Upload Photos (Optional)</div>
            <div style="font-size:13px;color:var(--gray-light);">Click to attach images of the issue — JPG, PNG up to 10MB each</div>
          </div>
        </div>

        <!-- Step 2 -->
        <div id="req-step-2" class="hidden">
          <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:24px;margin-bottom:20px;">Choose Date &amp; Time</h3>
          <div class="form-group"><label class="form-label">Preferred Date</label><input class="form-input" id="r-date" type="date"/></div>
          <label class="form-label" style="margin-bottom:12px;">Available Time Slots</label>
          <div class="slots-grid">
            <div class="time-slot" onclick="selectSlot(this)">8:00 AM</div>
            <div class="time-slot" onclick="selectSlot(this)">10:00 AM</div>
            <div class="time-slot booked">12:00 PM</div>
            <div class="time-slot" onclick="selectSlot(this)">2:00 PM</div>
            <div class="time-slot" onclick="selectSlot(this)">4:00 PM</div>
            <div class="time-slot" onclick="selectSlot(this)">6:00 PM</div>
          </div>
          <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:22px;margin:24px 0 16px;">Auto-Matched Technicians</h3>
          <div id="matched-techs"></div>
        </div>

        <!-- Step 3 -->
        <div id="req-step-3" class="hidden">
          <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:24px;margin-bottom:20px;">Confirm Your Request</h3>
          <div id="req-summary" style="border:1px solid var(--border);border-radius:10px;overflow:hidden;margin-bottom:20px;"></div>
          <div style="background:rgba(255,214,0,.08);border:1px solid rgba(255,214,0,.3);border-radius:10px;padding:16px;font-size:14px;margin-bottom:0;">
            <strong style="color:var(--yellow);">💳 M-Pesa Payment:</strong> Pay only after the technician completes the job to your satisfaction. No upfront payment required.
          </div>
        </div>

        <div style="display:flex;justify-content:space-between;margin-top:28px;gap:12px;">
          <button class="btn btn-ghost btn-md" id="req-back-btn" onclick="reqBack()" style="visibility:hidden;">← Back</button>
          <button class="btn btn-primary btn-md" id="req-next-btn" onclick="reqNext()">Continue →</button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ░░░░░░ BOOKING PAGE ░░░░░░ -->
