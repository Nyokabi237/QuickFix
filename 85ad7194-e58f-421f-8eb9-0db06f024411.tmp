        <label class="form-label" style="margin-bottom:12px;">Available Time Slots</label>
        <div class="slots-grid" style="margin-bottom:24px;">
          <div class="time-slot" onclick="selectSlot(this)">8:00 AM</div>
          <div class="time-slot" onclick="selectSlot(this)">10:00 AM</div>
          <div class="time-slot booked">12:00 PM</div>
          <div class="time-slot" onclick="selectSlot(this)">2:00 PM</div>
          <div class="time-slot" onclick="selectSlot(this)">4:00 PM</div>
          <div class="time-slot" onclick="selectSlot(this)">6:00 PM</div>
        </div>
        <div style="background:rgba(255,214,0,.08);border:1px solid rgba(255,214,0,.3);border-radius:10px;padding:16px;font-size:14px;margin-bottom:24px;">
          <strong style="color:var(--yellow);">💰 Estimated Cost: KSh 2,000–5,000</strong><br/>
          <span style="color:var(--gray-light);">Final quote provided on-site before work begins. Payment via M-Pesa.</span>
        </div>
        <button class="btn btn-primary btn-lg" style="width:100%;" onclick="confirmBooking()">✅ Confirm Booking</button>
