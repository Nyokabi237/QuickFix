            <div class="contact-item"><div class="contact-icon-box">✉️</div><div><div class="contact-label">Email</div><div class="contact-val">hello@quickfixkenya.co.ke<br/>support@quickfixkenya.co.ke</div></div></div>
            <div class="contact-item"><div class="contact-icon-box">📍</div><div><div class="contact-label">Office</div><div class="contact-val">ABC Place, Waiyaki Way<br/>Westlands, Nairobi, Kenya</div></div></div>
            <div class="contact-item"><div class="contact-icon-box">🕐</div><div><div class="contact-label">Working Hours</div><div class="contact-val">Mon–Sat: 7:00 AM – 8:00 PM<br/>Sunday: 9:00 AM – 5:00 PM<br/><strong style="color:var(--danger);">Emergency: 24/7</strong></div></div></div>
            <div class="map-placeholder">
              <div style="font-size:36px;">🗺️</div>
