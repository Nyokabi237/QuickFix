};

// ── STATE ──────────────────────────────────────────────────────────────────────
let currentUser = null;
let selectedRole = 'customer';
let emergencyOn = false;
let reqStep = 1;
let tsStep = 1;
let selectedServices = [];
let docUploads = {id:false,cert:false};

// ── PAGE NAVIGATION ───────────────────────────────────────────────────────────
function showPage(id) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  const target = document.getElementById('page-' + id);
  if (target) {
    target.classList.add('active');
    window.scrollTo(0, 0);
    document.querySelectorAll('.nav-link').forEach(l => l.classList.remove('active'));
    const navMap = {services:'services',search:'search',pricing:'pricing',about:'about',contact:'contact'};
    if (navMap[id]) {
      document.querySelectorAll('.nav-link').forEach(l => { if(l.textContent.toLowerCase().includes(navMap[id])) l.classList.add('active'); });
    }
    // lazy render
    if (id === 'search') renderSearch();
    if (id === 'pricing') renderPricing();
  }
}

// ── NAVBAR SCROLL ─────────────────────────────────────────────────────────────
window.addEventListener('scroll', () => {
  document.getElementById('navbar').classList.toggle('scrolled', window.scrollY > 20);
});

function toggleMenu() {
  document.getElementById('mobile-menu').classList.toggle('open');
}

// ── RENDER HOME ───────────────────────────────────────────────────────────────
function renderHomeTechs() {
  const g = document.getElementById('home-tech-grid');
  if (!g) return;
  g.innerHTML = TECHNICIANS.slice(0,4).map(t => techCardHTML(t)).join('');
}

function renderHomeTestimonials() {
  const g = document.getElementById('home-testimonials');
  if (!g) return;
  g.innerHTML = TESTIMONIALS.slice(0,3).map(t => `
    <div class="testimonial-card">
      <div class="stars">${starsHTML(t.rating)}</div>
      <p class="t-text">"${t.text}"</p>
      <div class="t-author">
        <div class="t-avatar">${t.avatar}</div>
        <div><div class="t-name">${t.name}</div><div class="t-detail">${t.location} &bull; ${t.service}</div></div>
      </div>
    </div>
  `).join('');
}

function renderHomePricing() {
  const g = document.getElementById('home-pricing-preview');
  if (!g) return;
  g.innerHTML = PRICING.slice(0,4).map(p => pricingCardHTML(p)).join('');
}

// ── SEARCH ────────────────────────────────────────────────────────────────────
function renderSearch() {
  const q = (document.getElementById('search-q')?.value || '').toLowerCase();
  const svc = document.getElementById('search-svc')?.value || 'all';
  const loc = document.getElementById('search-loc')?.value || '';
  const sortBy = document.getElementById('search-sort')?.value || 'rating';
  const availOnly = document.getElementById('search-avail')?.checked;

  let results = TECHNICIANS.filter(t => {
    if (q && !t.name.toLowerCase().includes(q) && !t.location.toLowerCase().includes(q) && !t.services.includes(q)) return false;
    if (svc !== 'all' && !t.services.includes(svc)) return false;
    if (loc && t.location !== loc) return false;
    if (availOnly && !t.available) return false;
    return true;
  }).sort((a,b) => {
    if (sortBy === 'rating') return b.rating - a.rating;
    if (sortBy === 'reviews') return b.reviews - a.reviews;
    return b.experience - a.experience;
  });

  const g = document.getElementById('search-results');
  const c = document.getElementById('search-count');
  if (g) g.innerHTML = results.length ? results.map(t => techCardHTML(t)).join('') : '<div style="grid-column:1/-1;text-align:center;padding:80px 24px;color:var(--gray-light);"><div style="font-size:48px;margin-bottom:16px;">🔍</div><h3 style="color:var(--white);font-size:20px;margin-bottom:8px;">No technicians found</h3><p>Try adjusting your filters.</p></div>';
  if (c) c.innerHTML = `Showing <strong style="color:var(--white);">${results.length}</strong> technician${results.length !== 1 ? 's' : ''}`;
}

function filterByService(svc) {
  const el = document.getElementById('search-svc');
  if (el) { el.value = svc; }
}

function toggleAvailLabel() {
  const checked = document.getElementById('search-avail').checked;
  const label = document.getElementById('avail-label');
  const dot = document.getElementById('avail-indicator');
  if (checked) {
    label.style.borderColor = 'var(--success)';
    label.style.color = 'var(--success)';
    dot.style.background = 'var(--success)';
  } else {
    label.style.borderColor = 'var(--border)';
    label.style.color = 'var(--gray-light)';
    dot.style.background = 'var(--gray-mid)';
  }
}

// ── TECH CARD HTML ─────────────────────────────────────────────────────────────
function techCardHTML(t, mini) {
  const svcBadges = t.services.map(sid => {
    const meta = {electrical:'⚡ Electrical',solar:'☀️ Solar',cctv:'📷 CCTV',internet:'📶 Internet'};
    const colors = {electrical:'yellow',solar:'orange',cctv:'green',internet:'blue'};
    return `<span class="badge badge-${colors[sid]}">${meta[sid]}</span>`;
  }).join('');
  const badgeColor = {yellow:'badge-yellow',orange:'badge-orange',green:'badge-green',blue:'badge-blue'}[t.badgeColor] || 'badge-green';
  return `
  <div class="card tech-card" onclick="showProfile(${t.id})" style="cursor:pointer;">
    <div class="tech-card-inner">
      <div style="display:flex;gap:14px;align-items:flex-start;">
        <div class="tech-avatar">
          ${t.emoji}
          ${t.verified ? '<div class="verified-badge">✓</div>' : ''}
        </div>
        <div class="tech-info">
          <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
            <span class="tech-name">${t.name}</span>
            <span class="badge ${badgeColor}">${t.badge}</span>
          </div>
          <div style="display:flex;align-items:center;gap:6px;margin-top:4px;">
            <div class="stars">${starsHTML(t.rating)}</div>
            <span style="font-size:13px;font-weight:700;">${t.rating}</span>
            <span style="color:var(--gray-light);font-size:13px;">(${t.reviews})</span>
          </div>
        </div>
      </div>
      <div class="tech-services-row">${svcBadges}</div>
      <div class="tech-meta">
        <span>📍 ${t.location}</span>
        <span>💼 ${t.experience}yr exp</span>
        <span style="margin-left:auto;color:${t.available?'var(--success)':'var(--danger)'};font-weight:700;font-size:12px;">
          <span class="avail-dot" style="background:${t.available?'var(--success)':'var(--danger)'}"></span>${t.available?'Available':'Busy'}
        </span>
      </div>
      <div class="tech-ctas" onclick="event.stopPropagation()">
        <button class="btn btn-primary btn-sm" style="flex:1;" onclick="callTech('${t.phone}')">📞 Call</button>
        <button class="btn btn-whatsapp btn-sm" style="flex:1;" onclick="whatsappTech(${t.id})">💬 WhatsApp</button>
      </div>
    </div>
  </div>`;
}

// ── PROFILE PAGE ──────────────────────────────────────────────────────────────
function showProfile(id) {
  const t = TECHNICIANS.find(x => x.id === id);
  if (!t) return;
  const colors = {electrical:'var(--yellow)',solar:'var(--orange)',cctv:'var(--success)',internet:'var(--blue)'};
  const svcBadges = t.services.map(sid => {
    const icons = {electrical:'⚡',solar:'☀️',cctv:'📷',internet:'📶'};
    const labels = {electrical:'Electrical',solar:'Solar Systems',cctv:'CCTV & Security',internet:'Internet & WiFi'};
    const c = colors[sid] || 'var(--yellow)';
    return `<div style="display:flex;align-items:center;gap:10px;padding:12px 18px;border-radius:8px;background:${c}18;border:1px solid ${c}44;">
      <span style="font-size:20px;">${icons[sid]}</span><span style="color:${c};font-weight:700;">${labels[sid]}</span>
    </div>`;
  }).join('');
  const portfolio = ['🔆 Solar array, Karen','⚡ DB board, Westlands','📹 Office CCTV, Kilimani','🌐 Network cabling, CBD','🔌 Emergency wiring, Kasarani','💡 Lighting install, Lavington'];

  const html = `
  <button onclick="showPage('search')" style="background:none;border:none;color:var(--gray-light);cursor:pointer;display:flex;align-items:center;gap:8px;font-size:14px;font-family:'Barlow',sans-serif;margin-bottom:24px;">← Back to Search</button>
  <div style="background:var(--black-soft);border:1px solid var(--border);border-radius:16px;overflow:hidden;">
    <div class="profile-header">
      <div class="profile-avatar-wrap">
        <div class="profile-avatar">${t.emoji}</div>
        ${t.verified?'<div class="profile-verified">✓ VERIFIED</div>':''}
      </div>
      <div style="flex:1;min-width:0;">
        <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:8px;">
          <h1 style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:36px;">${t.name}</h1>
          <span class="badge badge-yellow">${t.badge}</span>
        </div>
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px;">
          <div class="stars">${starsHTML(t.rating)}</div>
          <strong>${t.rating}</strong><span style="color:var(--gray-light);">(${t.reviews} reviews)</span>
        </div>
        <p style="color:var(--gray-light);line-height:1.75;max-width:500px;margin-bottom:14px;">${t.bio}</p>
        <div style="display:flex;gap:18px;flex-wrap:wrap;font-size:14px;color:var(--gray-light);">
          <span>📍 ${t.location}, Nairobi</span>
          <span>💼 ${t.experience} years experience</span>
          <span style="color:${t.available?'var(--success)':'var(--danger)'};font-weight:700;">● ${t.available?'Available Now':'Currently Busy'}</span>
        </div>
      </div>
      <div style="display:flex;flex-direction:column;gap:10px;min-width:180px;">
        <div style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:24px;color:var(--yellow);">${t.price}</div>
        <button class="btn btn-primary btn-md" onclick="showPage('booking')">📅 Book Now</button>
        <button class="btn btn-whatsapp btn-md" onclick="whatsappTech(${t.id})">💬 WhatsApp</button>
        <button class="btn btn-ghost btn-md">📞 ${t.phone}</button>
      </div>
    </div>
    <div class="profile-body">
      <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:22px;margin-bottom:16px;">Services Offered</h3>
      <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:36px;">${svcBadges}</div>
      <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:22px;margin-bottom:16px;">Portfolio</h3>
      <div class="portfolio-grid" style="margin-bottom:36px;">
        ${portfolio.map(p => {
          const [icon,...rest] = p.split(' ');
          return `<div class="portfolio-item"><span>${icon}</span><span>${rest.join(' ')}</span></div>`;
        }).join('')}
      </div>
      <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:22px;margin-bottom:16px;">Customer Reviews</h3>
      ${TESTIMONIALS.slice(0,3).map((r,i) => `
        <div style="padding:16px 0;${i<2?'border-bottom:1px solid var(--border);':''}">
          <div style="display:flex;justify-content:space-between;margin-bottom:10px;flex-wrap:wrap;gap:8px;">
            <div style="display:flex;align-items:center;gap:10px;">
              <div style="font-size:24px;">${r.avatar}</div>
              <div><div style="font-weight:700;font-size:14px;">${r.name}</div><div style="color:var(--gray-light);font-size:12px;">${r.location}</div></div>
            </div>
            <div class="stars">${starsHTML(r.rating)}</div>
          </div>
          <p style="color:var(--white-soft);font-size:14px;line-height:1.75;">"${r.text}"</p>
        </div>
      `).join('')}
    </div>
  </div>`;
  document.getElementById('profile-container').innerHTML = html;
  showPage('profile');
}

// ── PRICING ───────────────────────────────────────────────────────────────────
function renderPricing() {
  const g = document.getElementById('pricing-full');
  if (!g || g.dataset.rendered) return;
  const cats = ['electrical','solar','cctv','internet'];
  g.innerHTML = cats.map(cat => {
    const m = SVC_META[cat];
    const items = PRICING.filter(p => p.cat === cat);
    return `
      <div style="margin-bottom:40px;">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px;padding-bottom:12px;border-bottom:2px solid ${m.color};">
          <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:26px;color:${m.color};">${m.label}</h3>
        </div>
        <div class="grid-pricing">
          ${items.map(p => pricingCardHTML(p)).join('')}
        </div>
      </div>`;
  }).join('');
  g.dataset.rendered = '1';
}

function pricingCardHTML(p) {
  const catColors = {electrical:'var(--yellow)',solar:'var(--orange)',cctv:'var(--success)',internet:'var(--blue)'};
  const c = catColors[p.cat] || 'var(--yellow)';
  return `
  <div class="pricing-card">
    <div>
      <div class="pricing-service">${p.service}</div>
      <div class="pricing-time">${p.icon} ${p.time}</div>
    </div>
    <div class="pricing-amount" style="color:${c};">${p.range}</div>
  </div>`;
}

// ── STARS ─────────────────────────────────────────────────────────────────────
function starsHTML(rating) {
  return [1,2,3,4,5].map(i => `<span class="star ${i<=Math.round(rating)?'filled':''}">★</span>`).join('');
}

// ── REQUEST FLOW ───────────────────────────────────────────────────────────────
function toggleEmergency() {
  emergencyOn = !emergencyOn;
  const tog = document.getElementById('emerg-toggle');
  const sw = document.getElementById('emerg-switch');
  const lbl = document.getElementById('emerg-label');
  tog.classList.toggle('on', emergencyOn);
  sw.classList.toggle('on', emergencyOn);
  lbl.textContent = emergencyOn ? '🚨 EMERGENCY — Priority Dispatch Active' : 'Emergency Request';
}

function setEmergency(on) {
  emergencyOn = on;
  if (on) {
    const tog = document.getElementById('emerg-toggle');
    const sw = document.getElementById('emerg-switch');
    const lbl = document.getElementById('emerg-label');
    if (tog) tog.classList.add('on');
    if (sw) sw.classList.add('on');
    if (lbl) lbl.textContent = '🚨 EMERGENCY — Priority Dispatch Active';
  }
}

function updateStepUI() {
  ['sp1','sp2','sp3'].forEach((id,i) => {
    const el = document.getElementById(id);
    if (!el) return;
    el.className = 'step-dot ' + (i+1 < reqStep ? 'done' : i+1 === reqStep ? 'active' : 'inactive');
    if (i+1 < reqStep) el.textContent = '✓';
    else el.textContent = i+1;
  });
  ['sl1','sl2'].forEach((id,i) => {
    const el = document.getElementById(id);
    if (el) el.className = 'step-line ' + (i+1 < reqStep ? 'done' : 'inactive');
  });
  const labels = ['Step 1 of 3 — Your Details','Step 2 of 3 — Schedule','Step 3 of 3 — Confirm'];
  const lbl = document.getElementById('step-label');
  if (lbl) lbl.textContent = labels[reqStep-1];
  const backBtn = document.getElementById('req-back-btn');
  if (backBtn) backBtn.style.visibility = reqStep > 1 ? 'visible' : 'hidden';
  const nextBtn = document.getElementById('req-next-btn');
  if (nextBtn) nextBtn.textContent = reqStep === 3 ? '✅ Submit Request' : 'Continue →';
}

function reqNext() {
  if (reqStep === 1) {
    document.getElementById('req-step-1').classList.add('hidden');
    document.getElementById('req-step-2').classList.remove('hidden');
    renderMatchedTechs();
    reqStep = 2; updateStepUI();
  } else if (reqStep === 2) {
    document.getElementById('req-step-2').classList.add('hidden');
    document.getElementById('req-step-3').classList.remove('hidden');
    renderReqSummary();
    reqStep = 3; updateStepUI();
  } else {
    showRequestSuccess();
  }
}

function reqBack() {
  if (reqStep === 2) {
    document.getElementById('req-step-2').classList.add('hidden');
    document.getElementById('req-step-1').classList.remove('hidden');
    reqStep = 1; updateStepUI();
  } else if (reqStep === 3) {
    document.getElementById('req-step-3').classList.add('hidden');
    document.getElementById('req-step-2').classList.remove('hidden');
    reqStep = 2; updateStepUI();
  }
}

function renderMatchedTechs() {
  const svc = document.getElementById('r-svc')?.value || 'electrical';
  const matched = TECHNICIANS.filter(t => t.services.includes(svc) && t.available).slice(0,3);
  const g = document.getElementById('matched-techs');
  if (!g) return;
  g.innerHTML = matched.map(t => `
    <div style="display:flex;align-items:center;gap:14px;padding:14px;background:var(--black-mid);border-radius:10px;border:1px solid var(--border);margin-bottom:10px;">
      <div style="font-size:28px;">${t.emoji}</div>
      <div style="flex:1;">
        <div style="font-weight:700;">${t.name}</div>
        <div style="font-size:13px;color:var(--gray-light);">${t.location} • ${t.price}</div>
      </div>
      <div class="stars" style="font-size:12px;">${starsHTML(t.rating)}</div>
    </div>`).join('');
}

function renderReqSummary() {
  const name = document.getElementById('r-name')?.value || 'Not provided';
  const phone = document.getElementById('r-phone')?.value || 'Not provided';
  const loc = document.getElementById('r-loc')?.value || 'Not set';
  const svc = document.getElementById('r-svc')?.value || 'electrical';
  const svcLabels = {electrical:'⚡ Electrical',solar:'☀️ Solar Systems',cctv:'📷 CCTV & Security',internet:'📶 Internet & WiFi'};
  const date = document.getElementById('r-date')?.value || 'Flexible';
  const rows = [
    ['Name', name], ['Phone', phone], ['Location', loc],
    ['Service', svcLabels[svc]], ['Emergency', emergencyOn ? '🚨 YES — Priority Dispatch' : 'No'],
    ['Date', date]
  ];
  const g = document.getElementById('req-summary');
  if (!g) return;
  g.innerHTML = rows.map(([l,v]) => `
    <div style="display:flex;justify-content:space-between;padding:12px 16px;border-bottom:1px solid var(--border);font-size:14px;">
      <span style="color:var(--gray-light);">${l}</span>
      <span style="font-weight:700;color:${l==='Emergency'&&emergencyOn?'var(--danger)':'var(--white)'};">${v}</span>
    </div>`).join('');
}

function showRequestSuccess() {
  document.getElementById('page-request').innerHTML = `
  <div class="success-screen">
    <div style="max-width:520px;">
      <div class="success-icon">🎉</div>
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:40px;margin-bottom:14px;">Request Submitted!</h2>
      <p style="color:var(--gray-light);line-height:1.75;margin-bottom:32px;">We've matched you with available technicians. You'll receive an SMS and WhatsApp confirmation within 5 minutes.</p>
      <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap;">
        <button class="btn btn-primary btn-lg" onclick="showPage('search')">View Technicians</button>
        <button class="btn btn-ghost btn-lg" onclick="showPage('home')">Back to Home</button>
      </div>
    </div>
  </div>`;
  reqStep = 1;
}

function selectSlot(el) {
  if (el.classList.contains('booked')) return;
  el.closest('.slots-grid').querySelectorAll('.time-slot').forEach(s => s.classList.remove('selected'));
  el.classList.add('selected');
}

// ── BOOKING ───────────────────────────────────────────────────────────────────
function confirmBooking() {
  const date = document.getElementById('b-date')?.value;
  if (!date) { showToast('Please select a date', 'error'); return; }
  document.getElementById('booking-form-wrap').innerHTML = `
    <div style="text-align:center;padding:32px 0;">
      <div style="font-size:56px;margin-bottom:20px;">🎉</div>
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:34px;margin-bottom:12px;">Booking Confirmed!</h2>
      <p style="color:var(--gray-light);margin-bottom:28px;line-height:1.75;">Your appointment with <strong style="color:var(--white);">James Mwangi</strong> is confirmed for ${date}. You'll receive SMS confirmation within minutes.</p>
      <div style="background:var(--black-soft);border-radius:12px;border:1px solid var(--border);padding:20px;margin-bottom:28px;">
        <div style="display:flex;gap:10px;align-items:center;margin-bottom:14px;">
          <span style="font-size:30px;">👷</span>
          <div><div style="font-weight:700;">James Mwangi</div><div style="color:var(--gray-light);font-size:13px;">+254 712 345 678</div></div>
        </div>
        <button class="btn btn-whatsapp btn-md" style="width:100%;">💬 Message on WhatsApp</button>
      </div>
      <button class="btn btn-primary btn-lg" onclick="showPage('home')">Back to Home</button>
    </div>`;
  showToast('Booking confirmed! SMS sent to your phone.', 'success');
}

// ── AUTH ──────────────────────────────────────────────────────────────────────
function setRole(role) {
  selectedRole = role;
  ['customer','technician','admin'].forEach(r => {
    document.getElementById('role-'+r)?.classList.toggle('active', r === role);
  });
}

function doLogin() {
  const email = document.getElementById('l-email')?.value;
  const pass = document.getElementById('l-pass')?.value;
  if (!email || !pass) { showToast('Please enter email and password', 'error'); return; }
  const names = {customer:'Sarah Kiptoo',technician:'James Mwangi',admin:'Admin User'};
  currentUser = {name:names[selectedRole], role:selectedRole, email};
  updateNavAuth();
  showToast(`Welcome back, ${currentUser.name.split(' ')[0]}!`, 'success');
  if (selectedRole === 'admin') showPage('admin');
  else if (selectedRole === 'technician') {
    document.getElementById('tech-dash-name').textContent = `Welcome, ${currentUser.name.split(' ')[0]}!`;
    showPage('tech-dashboard');
  } else showPage('home');
}

function logout() {
  currentUser = null;
  updateNavAuth();
  showPage('home');
  showToast('Signed out successfully', 'info');
}

function goToDash() {
  if (!currentUser) { showPage('login'); return; }
  if (currentUser.role === 'admin') showPage('admin');
  else if (currentUser.role === 'technician') showPage('tech-dashboard');
  else showPage('home');
}

function updateNavAuth() {
  const userArea = document.getElementById('nav-user-area');
  const authArea = document.getElementById('nav-auth-area');
  const dashBtn = document.getElementById('nav-dash-btn');
  if (currentUser) {
    userArea.classList.add('hidden');
    authArea.classList.remove('hidden');
    if (dashBtn) dashBtn.textContent = `👤 ${currentUser.name.split(' ')[0]}`;
  } else {
    userArea.classList.remove('hidden');
    authArea.classList.add('hidden');
  }
}

// ── TECH SIGNUP ───────────────────────────────────────────────────────────────
function tsNext() {
  if (tsStep === 1) {
    document.getElementById('ts-step-1').classList.add('hidden');
    document.getElementById('ts-step-2').classList.remove('hidden');
    tsStep = 2; updateTsUI();
  } else if (tsStep === 2) {
    document.getElementById('ts-step-2').classList.add('hidden');
    document.getElementById('ts-step-3').classList.remove('hidden');
    tsStep = 3; updateTsUI();
  } else {
    submitTechSignup();
  }
}

function tsBack() {
  if (tsStep === 2) {
    document.getElementById('ts-step-2').classList.add('hidden');
    document.getElementById('ts-step-1').classList.remove('hidden');
    tsStep = 1; updateTsUI();
  } else if (tsStep === 3) {
    document.getElementById('ts-step-3').classList.add('hidden');
    document.getElementById('ts-step-2').classList.remove('hidden');
    tsStep = 2; updateTsUI();
  }
}

function updateTsUI() {
  [1,2,3].forEach(i => {
    const el = document.getElementById('ts'+i);
    if (!el) return;
    if (i < tsStep) { el.style.background='var(--success)'; el.style.color='var(--white)'; }
    else if (i === tsStep) { el.style.background='var(--yellow)'; el.style.color='var(--black)'; }
    else { el.style.background='var(--gray)'; el.style.color='var(--gray-light)'; }
  });
  const backBtn = document.getElementById('ts-back-btn');
  const nextBtn = document.getElementById('ts-next-btn');
  if (backBtn) backBtn.style.visibility = tsStep > 1 ? 'visible' : 'hidden';
  if (nextBtn) nextBtn.textContent = tsStep === 3 ? '✅ Submit Application' : 'Continue →';
}

function toggleServiceCheck(svc) {
  const idx = selectedServices.indexOf(svc);
  if (idx > -1) selectedServices.splice(idx, 1);
  else selectedServices.push(svc);
  const el = document.getElementById('stog-'+svc);
  const colors = {electrical:'var(--yellow)',solar:'var(--orange)',cctv:'var(--success)',internet:'var(--blue)'};
  if (el) {
    const on = selectedServices.includes(svc);
    el.style.borderColor = on ? colors[svc] : 'var(--border)';
    el.style.background = on ? colors[svc]+'1A' : 'transparent';
  }
}

function toggleDocUpload(key) {
  docUploads[key] = !docUploads[key];
  const el = document.getElementById('doc-'+key);
  const icon = document.getElementById('doc-'+key+'-icon');
  const status = document.getElementById('doc-'+key+'-status');
  if (docUploads[key]) {
    el.style.borderColor = 'var(--success)';
    el.style.background = 'rgba(34,197,94,.08)';
    if (icon) icon.textContent = '✅';
    if (status) { status.textContent = 'Uploaded ✓'; status.style.color = 'var(--success)'; }
  } else {
    el.style.borderColor = 'var(--border)';
    el.style.background = 'transparent';
    if (icon) icon.textContent = key === 'id' ? '🪪' : '📜';
    if (status) { status.textContent = 'Click to upload — JPG or PDF'; status.style.color = 'var(--gray-light)'; }
  }
}

function submitTechSignup() {
  const name = document.getElementById('ts-name')?.value || 'Technician';
  currentUser = {name, role:'technician'};
  updateNavAuth();
  showToast('Application submitted! Review within 24–48 hours.', 'success');
  document.getElementById('tech-dash-name').textContent = `Welcome, ${name.split(' ')[0]}!`;
  showPage('tech-dashboard');
}

// ── ADMIN TABS ─────────────────────────────────────────────────────────────────
function switchAdminTab(tab, btn) {
  ['overview','technicians','bookings','users'].forEach(t => {
    document.getElementById('admin-'+t)?.classList.toggle('hidden', t !== tab);
  });
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
}

// ── CONTACT ───────────────────────────────────────────────────────────────────
function submitContact() {
  const wrap = document.getElementById('contact-form-wrap');
  if (!wrap) return;
  wrap.innerHTML = `
    <div style="text-align:center;padding:48px 24px;">
      <div style="font-size:52px;margin-bottom:16px;">✅</div>
      <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:28px;margin-bottom:10px;">Message Sent!</h3>
      <p style="color:var(--gray-light);line-height:1.75;">We'll get back to you within 2 hours during business hours. For urgent matters, WhatsApp us directly.</p>
    </div>`;
  showToast('Message sent! We\'ll be in touch soon.', 'success');
}

// ── UTILS ─────────────────────────────────────────────────────────────────────
function callTech(phone) {
  showToast(`Calling ${phone}…`, 'info');
}

function whatsappTech(id) {
  const t = TECHNICIANS.find(x => x.id === id);
  if (t) showToast(`Opening WhatsApp for ${t.name}…`, 'success');
}

function showToast(msg, type='info') {
  const toast = document.getElementById('toast');
  const icon = document.getElementById('toast-icon');
  const msgEl = document.getElementById('toast-msg');
  const icons = {success:'✅',error:'❌',info:'ℹ️'};
  icon.textContent = icons[type] || 'ℹ️';
  msgEl.textContent = msg;
  toast.style.display = 'flex';
  clearTimeout(window._toastTimer);
  window._toastTimer = setTimeout(() => { toast.style.display = 'none'; }, 3200);
}

function filterSearch() { /* hero search just redirects */ }

// ── FOOTER HTML ───────────────────────────────────────────────────────────────
function buildFooter() {
  return `
  <div style="background:var(--black-soft);border-top:1px solid var(--border);padding:56px 0 24px;">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px;">
            <div style="width:34px;height:34px;background:var(--yellow);border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:16px;">⚡</div>
            <div><div style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:17px;">QuickFix</div><div style="font-size:9px;color:var(--yellow);letter-spacing:.12em;font-weight:700;">TECHNICIANS</div></div>
          </div>
          <p>Nairobi's most trusted platform for verified technical services — electrical, solar, CCTV, and internet.</p>
          <div class="social-row">
            <div class="social-btn" onclick="showToast('Follow us on WhatsApp!','success')">💬</div>
            <div class="social-btn" onclick="showToast('Follow us on Twitter!','info')">🐦</div>
            <div class="social-btn" onclick="showToast('Find us on Facebook!','info')">📘</div>
            <div class="social-btn" onclick="showToast('Follow on Instagram!','info')">📸</div>
          </div>
        </div>
        <div>
          <h4>Services</h4>
          <span class="footer-link" onclick="filterByService('electrical');showPage('search')">⚡ Electrical</span>
          <span class="footer-link" onclick="filterByService('solar');showPage('search')">☀️ Solar Systems</span>
          <span class="footer-link" onclick="filterByService('cctv');showPage('search')">📷 CCTV & Security</span>
          <span class="footer-link" onclick="filterByService('internet');showPage('search')">📶 Internet & WiFi</span>
        </div>
        <div>
          <h4>Platform</h4>
          <span class="footer-link" onclick="showPage('search')">Find Technicians</span>
          <span class="footer-link" onclick="showPage('request')">Request Service</span>
          <span class="footer-link" onclick="showPage('pricing')">Pricing Guide</span>
          <span class="footer-link" onclick="showPage('tech-signup')">Join as Technician</span>
          <span class="footer-link" onclick="showPage('login')">Login / Sign Up</span>
        </div>
        <div>
          <h4>Company</h4>
          <span class="footer-link" onclick="showPage('about')">About Us</span>
          <span class="footer-link" onclick="showPage('contact')">Contact</span>
          <span class="footer-link">Privacy Policy</span>
          <span class="footer-link">Terms of Service</span>
          <span class="footer-link">Emergency: 0800 QUICKFIX</span>
        </div>
      </div>
      <div class="footer-bottom">
        <span class="footer-copy">© 2025 QuickFix Technicians Ltd. All rights reserved. Nairobi, Kenya.</span>
        <div class="lang-btns">
          <span class="lang-btn" onclick="showToast('English selected','info')">🇬🇧 English</span>
          <span class="lang-btn" onclick="showToast('Kiswahili imechaguliwa!','success')">🇰🇪 Kiswahili</span>
        </div>
      </div>
    </div>
  </div>`;
}

// ── INIT ──────────────────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  // Inject footers
  ['home-footer','search-footer','services-footer','pricing-footer','about-footer','contact-footer','tdash-footer','admin-footer'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.outerHTML = buildFooter().replace('<div style=', `<div id="${id}" style=`);
  });

  renderHomeTechs();
  renderHomeTestimonials();
  renderHomePricing();

  // Set min date for date inputs
  const today = new Date().toISOString().split('T')[0];
  ['r-date','b-date'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.min = today;
  });
});
</script>
</body>
</html>
