<!-- ░░░░░░ LOGIN PAGE ░░░░░░ -->
<div id="page-login" class="page auth-page">
  <div class="auth-box">
    <div class="auth-logo">⚡</div>
    <h1 class="auth-title">Sign In to QuickFix</h1>
    <div class="auth-card">
      <p style="font-size:13px;color:var(--gray-light);margin-bottom:14px;text-align:center;">Select a role to demo different dashboards</p>
      <div class="role-switcher">
        <button class="role-btn active" id="role-customer" onclick="setRole('customer')">Customer</button>
        <button class="role-btn" id="role-technician" onclick="setRole('technician')">Technician</button>
        <button class="role-btn" id="role-admin" onclick="setRole('admin')">Admin</button>
      </div>
