      <div class="form-group"><label class="form-label">Password</label><input class="form-input" id="l-pass" placeholder="••••••••" type="password"/></div>
      <div style="display:flex;justify-content:flex-end;margin-bottom:20px;"><span style="font-size:13px;color:var(--yellow);cursor:pointer;">Forgot password?</span></div>
      <button class="btn btn-primary btn-md" style="width:100%;" onclick="doLogin()">Sign In</button>
      <div style="margin-top:18px;text-align:center;font-size:14px;color:var(--gray-light);">No account? <span style="color:var(--yellow);cursor:pointer;" onclick="showPage('tech-signup')">Register as Technician</span></div>
    </div>
  </div>
